version: '3.8'

services:
  db:
    image: mysql:8.0
    container_name: barber-db
    restart: always
    ports:
-     - "3306:3306"
+     - "3307:3306"
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: barberdb      
      MYSQL_USER: barber_user       
      MYSQL_PASSWORD: barber_pass   
    volumes:
      - db_data:/var/lib/mysql
    healthcheck:
      test: ['CMD', 'mysqladmin', 'ping', '-h', 'localhost', '--silent']
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s

volumes:
  db_data:
